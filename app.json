{
  "expo": {
    "name": "Trip Plan",
    "slug": "trip-plan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "tripplan",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tripplan.app"
    },
    "android": {
      "package": "com.tripplan.app",
      "config": {
        "googleMaps": {
          "apiKey": "REMPLACER_PAR_CLE_MAPS_ANDROID"
        }
      }
    },
    "plugins": [
      "expo-image-picker",
      "expo-web-browser",
      "expo-notifications",
      "expo-localization",
      "expo-font"
    ]
  }
}
