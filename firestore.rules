rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Helper: renvoie le doc trip pour verifier les permissions
    function getTrip(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }

    function canViewTrip(tripId) {
      let t = getTrip(tripId);
      return isOwner(t.ownerId) || request.auth.uid in t.sharedWith;
    }

    function canEditTrip(tripId) {
      return isOwner(getTrip(tripId).ownerId);
    }

    // users/{userId}
    match /users/{userId} {
      // Tout utilisateur authentifie peut lire un profil (necessaire pour
      // la recherche par email et l'affichage des utilisateurs partages).
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // trips/{tripId}
    match /trips/{tripId} {
      allow read: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid ||
         request.auth.uid in resource.data.sharedWith);

      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.sharedWith is list;

      // L'owner peut tout modifier. Les autres : jamais.
      allow update, delete: if isSignedIn() &&
        resource.data.ownerId == request.auth.uid;

      // days/{dayId}
      match /days/{dayId} {
        allow read: if canViewTrip(tripId);
        allow create, update, delete: if canEditTrip(tripId);

        // events/{eventId}
        match /events/{eventId} {
          allow read: if canViewTrip(tripId);
          allow create, update, delete: if canEditTrip(tripId);
        }
      }
    }
  }
}
