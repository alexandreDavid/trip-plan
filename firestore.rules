rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Helper: renvoie le doc trip pour verifier les permissions
    function getTrip(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }

    function canViewTrip(tripId) {
      let t = getTrip(tripId);
      return isOwner(t.ownerId) || request.auth.uid in t.sharedWith;
    }

    // L'owner peut tout editer ; un collaborateur peut editer le contenu
    // (jours/evenements) uniquement si son role est 'editor'.
    function canEditTrip(tripId) {
      let t = getTrip(tripId);
      return isOwner(t.ownerId) ||
        (request.auth.uid in t.sharedWith &&
         t.get(['roles', request.auth.uid], 'viewer') == 'editor');
    }

    // Auto-ajout d'un invité comme LECTEUR via le lien d'invitation.
    // L'invité prouve qu'il connaît le lien en écrivant joinToken == inviteToken
    // (il ne peut pas lire le trip avant d'être membre). Il ne peut s'ajouter que
    // lui-même, sans rien retirer ni changer le proprietaire/le jeton.
    function isLinkJoin() {
      let uid = request.auth.uid;
      let before = resource.data;
      let after = request.resource.data;
      return before.get('inviteToken', null) != null
        && after.get('joinToken', '') == before.inviteToken
        && !(uid in before.sharedWith)
        && (uid in after.sharedWith)
        && after.sharedWith.size() == before.sharedWith.size() + 1
        && after.sharedWith.hasAll(before.sharedWith)
        && after.ownerId == before.ownerId
        && after.get('inviteToken', null) == before.inviteToken
        && after.get('roles', {}).get(uid, '') == 'viewer';
    }

    // users/{userId}
    match /users/{userId} {
      // Tout utilisateur authentifie peut lire un profil (necessaire pour
      // la recherche par email et l'affichage des utilisateurs partages).
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // Lecture collection-group des evenements (timeline + budget global).
    // Une requete collectionGroup('events') ne peut pas s'appuyer sur le
    // wildcard de chemin {tripId} : on autorise via le champ tripId du document.
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn() && canViewTrip(resource.data.tripId);
    }

    // trips/{tripId}
    match /trips/{tripId} {
      allow read: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid ||
         request.auth.uid in resource.data.sharedWith);

      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.sharedWith is list;

      // L'owner peut tout modifier ; un invité peut s'ajouter en lecteur via lien.
      allow update: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid || isLinkJoin());
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // days/{dayId}
      match /days/{dayId} {
        allow read: if canViewTrip(tripId);
        allow create, update, delete: if canEditTrip(tripId);

        // events/{eventId}
        match /events/{eventId} {
          allow read: if canViewTrip(tripId);
          allow create, update, delete: if canEditTrip(tripId);
        }
      }

      // participants/{participantId} — personnes du partage de dépenses
      match /participants/{participantId} {
        allow read: if canViewTrip(tripId);
        allow create, update, delete: if canEditTrip(tripId);
      }

      // expenses/{expenseId} — dépenses partagées
      match /expenses/{expenseId} {
        allow read: if canViewTrip(tripId);
        allow create, update, delete: if canEditTrip(tripId);
      }
    }
  }
}
